# Core crawl settings
MAX_PAGES=200
PAGE_CONCURRENCY=2
# SINCE=2024-01-01
SYNC_MODE=hybrid
HEAD_SKIP_OK_PAGES=true
HEAD_RECHECK_PAGES=10
DATA_DIR=./output/aliyun_cve

# Active channel: aliyun | trickest_cve | cvelistv5
CHANNEL=cvelistv5

# Data directories per channel
TRICKEST_DATA_DIR=./output/trickest_cve
CVELISTV5_DATA_DIR=./output/cvelistv5

# RawDB backend: file / sqlite / dual
RAWDB_STORAGE_BACKEND=dual
# RAWDB_SQLITE_PATH=./output/aliyun_cve/raw.db

# API bind
RAWDB_API_HOST=127.0.0.1
RAWDB_API_PORT=8787

# GitHub API (required for github-deps)
# GITHUB_TOKEN=ghp_xxx
GITHUB_SBOM_CONCURRENCY=4
GITHUB_SBOM_HOURLY_BUDGET=4500
# GITHUB_SBOM_SQLITE_PATH=   # leave empty to use cvelistv5's raw.db

# Optional integrations
# LLM__API_KEY=sk-xxx
# LLM__BASE_URL=https://your-proxy/v1

# Optional runtime (default is ./logs)
LOG_DIR=./logs
